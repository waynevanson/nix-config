{
	"$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
	"final_space": true,
	"palette": {
		"os": "#ACB0BE",
		"closer": "p:os",
		"pink": "#F5C2E7",
		"lavender": "#B4BEFE",
		"blue": "#89B4FA"
	},
	"blocks": [
		{
			"type": "prompt",
			"alignment": "left",
			"segments": [
				{
					"foreground": "p:blue",
					"style": "plain",
					"template": "{{ .UserName }}@{{ .HostName }} ",
					"type": "session"
				},
				{
					"type": "path",
					"style": "plain",
					"foreground": "#ffffff"
				},
				{
					"foreground": "p:lavender",
					"options": {
						"branch_icon": "\ue725 ",
						"cherry_pick_icon": "\ue29b ",
						"commit_icon": "\uf417 ",
						"fetch_status": false,
						"fetch_upstream_icon": false,
						"merge_icon": "\ue727 ",
						"no_commits_icon": "\uf0c3 ",
						"rebase_icon": "\ue728 ",
						"revert_icon": "\uf0e2 ",
						"tag_icon": "\uf412 "
					},
					"template": "{{ .HEAD }} ",
					"style": "plain",
					"type": "git"
				}
			]
		}
	]
}
